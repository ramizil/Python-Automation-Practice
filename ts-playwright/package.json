{
  "name": "ts-playwright-practice",
  "version": "1.0.0",
  "description": "TypeScript + Playwright automation practice (UI + API + mocks)",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --grep @ui",
    "test:api": "playwright test --grep @api",
    "test:headed": "playwright test --headed",
    "test:exercise": "playwright test -c playwright.exercises.config.ts",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "ajv": "^8.17.1",
    "typescript": "^5.7.2"
  }
}
